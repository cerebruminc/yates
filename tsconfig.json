{
	"compilerOptions": {
		"esModuleInterop": true,
		"target": "ES2020",
		"lib": ["es2020"],
		"module": "CommonJS",
		"outDir": "./dist",
		"sourceMap": true,
		"strict": true,
		"useUnknownInCatchVariables": false,
		"noUnusedParameters": true,
		"declaration": true,
		"downlevelIteration": true
	},
	"include": ["src/**/*", "test/types/index.ts"]
}
